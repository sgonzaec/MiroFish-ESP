# =============================================
# MIROFISH-ESP — CONFIGURACIÓN DE VARIABLES
# Copia este archivo como .env y agrega tus keys
# cp .env.example .env
# =============================================

# LLM API — Compatible con cualquier API formato OpenAI
# Recomendado: Gemini 3 Flash (Google AI Studio - gratis)
# Obtén tu key en: https://aistudio.google.com/
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=gemini-3-flash-preview

# Zep Cloud — Memoria de agentes
# Tier gratuito disponible en: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# URL del backend (cambia por tu IP si usas VPS)
VITE_API_BASE_URL=http://localhost:5001
